{
  "manifest_version": 3,
  "name": "ParamXray",
  "version": "1.0.0",
  "description": "Advanced passive reconnaissance and vulnerability discovery tool for parameters, subdomains, APIs, and secrets.",
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ParamXray Dashboard",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "minimum_chrome_version": "88"
}
